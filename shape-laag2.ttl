@prefix dia: <http://bpm4mc2.org/def/dia-laag1#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix eli: <http://data.europa.eu/eli/ontology#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix wa: <http://bpm4mc2.org/def/regelvorming#>.
@prefix ui: <http://www.w3.org/ns/ui#>.

dia:Bepaling a sh:NodeShape;
  sh:targetClass wa:Bepaling;
  sh:property [ sh:path dct:source; sh:name "grondslag"];
  sh:property [ sh:path wa:normeert];
  sh:property [ sh:path wa:beperkt];
  sh:property [ sh:path skos:related; sh:name "verwijst naar"];
  sh:property [ sh:path dct:subject; sh:name "betreft"];
.

dia:Handeling a sh:NodeShape;
  sh:name "Handeling";
  sh:targetClass wa:Handeling;
  sh:property [ sh:path wa:actor];
.

dia:Begrip a sh:NodeShape;
  sh:name "Begrip";
  sh:targetClass skos:Concept;
.

dia:Tekstfragment a sh:NodeShape;
  ui:color "#A0A0A0";
  sh:targetClass eli:LegalResourceSubdivision;
.

@prefix dia: <http://bpm4mc2.org/def/dia-laag1#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix eli: <http://data.europa.eu/eli/ontology#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.
@prefix ui: <http://www.w3.org/ns/ui#>.

dia:Bron a sh:NodeShape;
  ui:color "#D0D0D0";
  sh:targetClass eli:LegalResource;
.

dia:Tekstfragment a sh:NodeShape;
  ui:color "#A0A0A0";
  sh:targetClass eli:LegalResourceSubdivision;
  sh:property [ sh:path dct:isPartOf; sh:name "onderdeel van"];
  sh:property [ sh:path eli:cites; sh:name "citeert"];
.

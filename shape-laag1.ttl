@prefix dia: <http://bpm4mc2.org/def/dia-laag1#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix dct: <http://purl.org/dc/terms/>.
@prefix eli: <http://data.europa.eu/eli/ontology#>.
@prefix sh: <http://www.w3.org/ns/shacl#>.

dia:LegalResource a sh:NodeShape;
  sh:targetClass eli:LegalResource;
.

dia:LegalResource a sh:NodeShape;
 sh:targetClass eli:LegalResourceSubdivision;
 sh:property [ sh:path dct:isPartOf];
 sh:property [ sh:path eli:cites];
.
